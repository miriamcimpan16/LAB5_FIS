[STUDENT]-(LOG IN)
[STUDENT]-(VIEW UNI DETAILS)
[STUDENT]-(VIEW GRADES)
(LOG IN)>(VERIFY PASSWORD)
(LOG IN)<(DISPLAY ACCOUNT LOCKED)
[TEACHER]-(LOG IN)
[TEACHER]-(ADD GRADES)
[TEACHER]-(ADD STUDENT)
[TEACHER]-(CREATE ACCOUNTS)
[ADMIN]-(CREATE ACCOUNTS)
[ADMIN]-(ADD SUBJECT)
(ADD STUDENT)<(DISPLAY 'ALREADY ADDED')
(ADD GRADES)<(VIEW STATISTICS)
(CREATE ACCOUNTS)<(DISPLAY 'ALREADY CREATED')